<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Huy Future Shop | <%= typeof title !== 'undefined' ? title : 'An Giang' %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        :root { --primary-color: #ffffff; --dark-color: #212529; }
        body { background-color: #f4f7f6; }
        .navbar-brand { font-weight: 800; letter-spacing: 1px; color: var(--primary-color) !important; }
        .main-content { min-height: 80vh; }
        footer { background: var(--dark-color); color: #aaa; padding: 30px 0; border-top: 4px solid var(--primary-color); }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
        <div class="container">
            <a class="navbar-brand" href="/">
                <i class="fa-solid fa-motorcycle"></i> HUY FUTURE SHOP
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="/"></i>Trang Chủ</a></li>
                    <li class="nav-item"><a class="nav-link" href="/khachhang">Khách Hàng</a></li>
                    <li class="nav-item"><a class="btn btn-outline-danger ms-lg-3" href="/khachhang/addkh">Đăng Ký Tư Vấn</a></li>
                </ul>
            </div>
        </div>
    </nav>
    <div class="main-content">
        <%- body -%>

    <footer>
        <div class="container text-center">
            <p class="mb-1 text-white fw-bold">HUY FUTURE SHOP - CHUYÊN FUTURE 125 FI</p>
            <p class="small mb-0">Thiết kế bởi: Nguyễn Phước Toàn - An Giang</p>
            <div class="mt-2">
                <i class="fab fa-facebook me-3"></i><i class="fab fa-youtube"></i>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
