<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Xe Máy Phát Huy | <%= typeof title !=='undefined' ? title : 'An Giang' %>
    </title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;700;800&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    
    <style>
        :root {
            --sidebar-width: 250px;
            --honda-red: #dc3545;
            --dark-sidebar: #1a1d20;
        }

        /* Sidebar cố định bên trái */
        .admin-sidebar {
            width: var(--sidebar-width);
            height: 100vh;
            position: fixed;
            top: 0;
            left: 0;
            background-color: var(--dark-sidebar);
            padding-top: 20px;
            z-index: 100;
            transition: all 0.3s;
        }

        /* Phần nội dung bên phải phải lùi ra để không bị menu đè lên */
        .admin-main-content {
            margin-left: var(--sidebar-width);
            padding: 30px;
            min-height: 100vh;
            background-color: #f8f9fa;
        }

        /* Style cho các mục Menu */
        .nav-menu {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .nav-menu-item a {
            display: flex;
            align-items: center;
            padding: 15px 25px;
            color: #7d90a2;
            text-decoration: none;
            transition: 0.3s;
            border-left: 4px solid transparent;
        }

        .nav-menu-item a i {
            width: 25px;
            font-size: 1.1rem;
            margin-right: 10px;
        }

        .nav-menu-item a:hover,
        .nav-menu-item.active a {
            color: white;
            background: rgba(220, 53, 69, 0.1);
            border-left: 4px solid var(--honda-red);
        }

        .sidebar-brand {
            padding: 0 25px 30px;
            color: white;
            border-bottom: 1px solid #343a40;
            margin-bottom: 20px;
        }

        .admin-main-content {
            margin-left: var(--sidebar-width);
            /* Đẩy nội dung sang phải 250px */
            padding: 30px;
            min-height: 100vh;
            background-color: #f8f9fa;
        }
    </style>
</head>

<body>
    <div class="admin-sidebar">
        <div class="sidebar-brand">
            <h4 class="fw-bold mb-0 text-danger">Xe Máy Phát Huy</h4>
            <small class="text">Trang Quản Trị Nội Dung</small>
        </div>

        <ul class="nav-menu">
            <li class="nav-menu-item">
                <a href="/admin">
                    <i class="fa-solid fa-gauge"></i> <span>Dashboard</span>
                </a>
            </li>

            <li class="nav-menu-item">
                <a href="/admin/quanlixemay">
                    <i class="fa-solid fa-motorcycle"></i> <span>Quản lý Xe máy</span>
                </a>
            </li>

            <li class="nav-menu-item">
                <a href="/admin/quanlikhachhang">
                    <i class="fa-solid fa-users"></i> <span>Quản lý Khách hàng</span>
                </a>
            </li>

            <li class="nav-menu-item">
                <a href="/admin/phukien">
                    <i class="fa-solid fa-screwdriver-wrench"></i> <span>Quản lý Phụ kiện</span>
                </a>
            </li>

            <li class="nav-menu-item">
                <a href="/admin/quanlislide">
                    <i class="fa-solid fa-images"></i> <span>Quản lý Slide</span>
                </a>
            </li>

            <li class="nav-menu-item mt-5">
                <a href="/" class="text-warning">
                    <i class="fa-solid fa-house"></i> <span>Xem Trang chủ</span>
                </a>
            </li>
        </ul>
    </div>
    <div class="admin-main-content">
        <nav style="text-align: right">
            <h4>Xin chào <strong>
                    <%= user.fullname %>
                </strong>!</h4>
            <a href="/auth/logout" class="text-danger"
                onclick="return confirm('Toàn có chắc chắn muốn đăng xuất không?')">
                <i class="fa-solid fa-right-from-bracket"></i> <span>Đăng xuất</span>
            </a>
        </nav>
        <%- body -%>
    </div>
    <script src="/javascript/admscript.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    // Dùng cú pháp EJS để kiểm tra xem Backend có gửi biến 'thongBao' về không
    // Chữ 'undefined' phải để trong dấu nháy
    const thongBaoTuServer = '<%- typeof thongBao !== "undefined" ? JSON.stringify(thongBao) : "" %>';

    if (thongBaoTuServer) {
        // Chuyển chuỗi chữ từ Server thành Object JavaScript
        const dataAlert = JSON.parse(thongBaoTuServer);
        
        // Kích nổ hộp thoại SweetAlert2 siêu đẹp
        Swal.fire({
            icon: dataAlert.icon,   // 'success', 'error', 'warning', 'info'
            title: dataAlert.title, // Tiêu đề bự
            text: dataAlert.text,   // Đoạn mô tả nhỏ ở dưới
            confirmButtonText: 'OK',
            confirmButtonColor: '#3085d6',
            timer: 3000 // Tự động đóng sau 3 giây nếu khách không bấm nút
        });
    }
</script>
</body>

</html>