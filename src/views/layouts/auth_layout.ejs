<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | Huy Future</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        body {
            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .auth-card {
            width: 400px;
            border: none;
            border-radius: 15px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        }
        .btn-honda {
            background-color: #dc3545;
            border: none;
            padding: 12px;
            font-weight: bold;
        }
        .btn-honda:hover { background-color: #bb2d3b; }
    </style>
</head>
<body>
    <%- body %>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    // Dùng cú pháp EJS để kiểm tra xem Backend có gửi biến 'thongBao' về không
    // Chữ 'undefined' phải để trong dấu nháy
    const thongBaoTuServer = '<%- typeof thongBao !== "undefined" ? JSON.stringify(thongBao) : "" %>';

    if (thongBaoTuServer) {
        // Chuyển chuỗi chữ từ Server thành Object JavaScript
        const dataAlert = JSON.parse(thongBaoTuServer);
        
        // Kích nổ hộp thoại SweetAlert2 siêu đẹp
        Swal.fire({
            icon: dataAlert.icon,   // 'success', 'error', 'warning', 'info'
            title: dataAlert.title, // Tiêu đề bự
            text: dataAlert.text,   // Đoạn mô tả nhỏ ở dưới
            confirmButtonText: 'OK',
            confirmButtonColor: '#3085d6',
            timer: 3000 // Tự động đóng sau 3 giây nếu khách không bấm nút
        });
    }
</script>
</body>
</html>