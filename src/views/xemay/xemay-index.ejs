<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <a href="/xemay/addxemay" class="btn btn-dark shadow-sm">
            <i class="fa-solid fa-plus me-2"></i>Thêm Xe Mới
        </a>
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4">
        <% if (danhSachXe && danhSachXe.length> 0) { %>
            <% danhSachXe.forEach(xe=> { %>
                <div class="col">
                    <div class="card h-100 shadow-sm border-0 item-card">
                        <img src="<%= xe.linkanh %>" class="card-img-top p-2" alt="<%= xe.tenxe %>"
                            style="border-radius: 15px;">

                        <div class="card-body d-flex flex-column">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <span class="badge bg-danger">
                                    <%= xe.hangxe %>
                                </span>
                                <span class="text-muted small">
                                    <%= xe.loaixe %>
                                </span>
                            </div>

                            <h5 class="card-title fw-bold text-dark">
                                <%= xe.tenxe %>
                            </h5>
                            <p class="card-text text-primary fw-bold fs-5 mb-1">
                                <%= xe.gia.toLocaleString('vi-VN') %> ₫
                            </p>
                            <p class="card-text text-muted small mb-3">
                                <i class="fa-solid fa-engine me-1"></i> Dung tích: <%= xe.dungtichxilanh || 'N/A' %>
                            </p>
                            <a href="#" class="btn btn-info">Xem chi tiết</a>
                        </div>
                    </div>
                </div>
                <% }) %>
                    <% } else { %>
                        <div class="col-12 text-center py-5">
                            <p class="text-muted">Chưa có xe nào trong danh sách.</p>
                        </div>
                        <% } %>
    </div>
    <% if (typeof tongSoTrang !== 'undefined' && tongSoTrang > 1) { %>
        <nav aria-label="Page navigation" class="mt-5">
            <ul class="pagination justify-content-center shadow-sm d-inline-flex" style="border-radius: 10px; overflow: hidden;">
                
                <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
                    <a class="page-link border-0 text-dark bg-light py-2 px-3" href="/xemay?page=<%= currentPage - 1 %>">
                        <i class="fa-solid fa-chevron-left"></i>
                    </a>
                </li>

                <% for (let i = 1; i <= tongSoTrang; i++) { %>
                    <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                        <a class="page-link border-0 py-2 px-3 <%= currentPage === i ? 'bg-dark text-white fw-bold' : 'text-dark bg-white' %>" 
                           href="/xemay?page=<%= i %>">
                            <%= i %>
                        </a>
                    </li>
                <% } %>

                <li class="page-item <%= currentPage === tongSoTrang ? 'disabled' : '' %>">
                    <a class="page-link border-0 text-dark bg-light py-2 px-3" href="/xemay?page=<%= currentPage + 1 %>">
                        <i class="fa-solid fa-chevron-right"></i>
                    </a>
                </li>

            </ul>
        </nav>
    <% } %>
</div>