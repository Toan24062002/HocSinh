<div class="card auth-card p-4">
    <div class="text-center mb-4">
        <div class="mb-3">
            <i class="fa-solid fa-envelope-circle-check text-danger fa-3x"></i>
        </div>
        <h3 class="fw-bold">Xác thực Email</h3>
        <p class="text-muted">Mã OTP đã được gửi đến <br><strong class="text-dark"><%= email %></strong></p>
    </div>

    <!-- Hiển thị thông báo lỗi nếu nhập sai OTP -->
    <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-danger py-2 small text-center">
            <i class="fa-solid fa-triangle-exclamation me-2"></i><%= error %>
        </div>
    <% } %>

    <form action="/auth/xacthuc_otp" method="POST" id="otpForm">
        <input type="text" class="form-control mb-3" name="userOtp" id="fullOtp">

        <button type="submit" class="btn btn-danger btn-honda w-100 mb-3 text-white">XÁC NHẬN</button>
    </form>

    <div class="text-center">
        <p class="small text-muted mb-2">Không nhận được mã?</p>
        <div id="countdown" class="small fw-bold text-danger mb-2">Mã hết hạn sau: <span id="timer">05:00</span></div>
        <a href="/auth/resend-otp" id="resendBtn" class="text-decoration-none small fw-bold text-danger d-none">Gửi lại mã mới</a>
    </div>
</div>

<style>
    .otp-field {
        width: 45px;
        height: 55px;
        text-align: center;
        font-size: 1.5rem;
        font-weight: bold;
        border: 2px solid #ced4da;
        border-radius: 10px;
    }
    .otp-field:focus {
        border-color: #dc3545;
        box-shadow: 0 0 0 0.25rem rgba(220, 53, 69, 0.25);
    }
</style>