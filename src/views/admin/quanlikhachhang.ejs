<dic class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-danger fw-bold mt-3">DANH SÁCH KHÁCH HÀNG</h2>
        <a href="/khachhang/addkh" class="btn btn-success shadow-sm">
            <i class="fa-solid fa-plus me-2"></i>Thêm Mới
        </a>
    </div>

    <div class="card shadow border-0">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>STT</th>
                        <th>Họ và Tên</th>
                        <th>Email</th>
                        <th>Số Điện Thoại</th>
                        <th>Địa Chỉ</th>
                        <th class="text-center">Thao Tác</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (customers && customers.length> 0) { %>
                        <% customers.forEach((item, index)=> { %>
                            <tr>
                                <td class="fw-bold">
                                    <%= index + 1 %>
                                </td>
                                <td class="text-primary fw-bold">
                                    <%= item.name %>
                                </td>
                                <td>
                                    <%= item.email %>
                                </td>
                                <td>
                                    <%= item.phone || 'Chưa có' %>
                                </td>
                                <td>
                                    <%= item.address %>
                                </td>
                                <td class="text-center">
                                    <div class="btn-group" role="group">
                                        <a href="/khachhang/edit/<%= item._id %>"
                                            class="btn btn-sm btn-outline-primary">
                                            <i class="fa-solid fa-pen-to-square"></i>
                                        </a>
                                        <a href="/khachhang/delete/<%= item._id %>"
                                            class="btn btn-sm btn-outline-danger"
                                            onclick="return confirm('Bạn có chắc chắn muốn xóa khách hàng này không?')">
                                            <i class="fa-solid fa-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                            <% }) %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="6" class="text-center py-4 text-muted">
                                            <i>Chưa có khách hàng nào trong danh sách.</i>
                                        </td>
                                    </tr>
                                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</dic>