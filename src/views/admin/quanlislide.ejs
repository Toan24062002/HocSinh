<div class="container">
    <nav><button class="btn btn-sm btn-outline-primary" type="button" data-bs-toggle="offcanvas"
            data-bs-target="#offcanvasAdd">
            <i class="bi bi-plus-circle"></i> Thêm ảnh slide
        </button></nav>

    <div class="card shadow border-0 mt-3">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>STT</th>
                        <th>Tên ảnh</th>
                        <th>Link ảnh</th>
                        <th class="text-center">Thao Tác</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (dsslide && dsslide.length> 0) { %>
                        <% dsslide.forEach((item, index)=> { %>
                            <tr>
                                <td class="fw-bold">
                                    <%= item.stt %>
                                </td>
                                <td class="text-primary fw-bold">
                                    <%= item.tenanhslide %>
                                </td>
                                <td>
                                    <img src="<%= item.linkanh %>" alt="<%= item.tenanhslide %>"
                                        style="width: 100px; height: auto; border-radius: 5px;">
                                </td>
                                <td class="text-center">
                                    <div class="btn-group" role="group">
                                        <button class="btn btn-sm btn-outline-primary" type="button"
                                            data-bs-toggle="offcanvas" data-bs-target="#offcanvasEdit"
                                            onclick="fillData('<%= item._id %>', '<%= item.tenxe %>', '<%= item.hangxe %>', '<%= item.gia %>', '<%= item.dungtichxilanh %>')">
                                            <i class="fa-solid fa-pen-to-square"></i>
                                        </button>
                                        <a href="/xemay/delete/<%= item._id %>" class="btn btn-sm btn-outline-danger"
                                            onclick="return confirm('Bạn có chắc chắn muốn xóa khách hàng này không?')">
                                            <i class="fa-solid fa-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>   
                            <% }) %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="6" class="text-center py-4 text-muted">
                                            <i>Chưa có ảnh </i>
                                        </td>
                                    </tr>
                                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>
<!--Thêm-->
<div class="offcanvas offcanvas-end" tabindex="-1" id="offcanvasAdd" style="width: 400px;">
    <div class="offcanvas-header bg-dark text-white">
        <h5 class="offcanvas-title fw-bold">Thêm ảnh slide</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas"></button>
    </div>
    <div class="offcanvas-body">
        <form action="/slide/addslide" method="POST">
            <div class="col-md-6 mb-3">
                <label class="form-label fw-bold">Tên ảnh</label>
                <input type="text" name="tenanhslide" class="form-control" placeholder="slide 1">
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label fw-bold">URL</label>
                <input type="text" name="linkanh" class="form-control" placeholder="url ảnh...">
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label fw-bold">Thứ tự</label>
                <input type="number" name="stt" class="form-control" placeholder="thứ tự hiển thị 1-4">
            </div>
            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-danger btn-lg fw-bold shadow">
                    <i class="fa-solid fa-save me-2"></i>Lưu Ảnh
                </button>
                <a href="/admin/quanlislide" class="btn btn-outline-secondary">Quay lại danh sách</a>
            </div>
        </form>
    </div>
</div>